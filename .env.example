# Oura OAuth application credentials, from https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Must exactly match the redirect URI registered on the Oura application.
# Local dev: http://localhost:3000/api/oura/callback
# Production: https://your-domain.example/api/oura/callback
OURA_REDIRECT_URI=http://localhost:3000/api/oura/callback

# Solo use fallback: a Personal Access Token from https://cloud.ouraring.com/personal-access-tokens
# When set, the app can talk to the Oura API with no OAuth flow at all.
OURA_PERSONAL_ACCESS_TOKEN=

# 32+ character random string used to encrypt the httpOnly token cookie.
# Generate one with: openssl rand -base64 48
SESSION_SECRET=
